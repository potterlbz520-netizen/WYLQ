const CATEGORIES = ["All", "Daily Life", "Sports", "Cars", "Food", "Work", "Tech"];
const ROOT_TYPES = ["All", "Root", "Prefix", "Suffix", "Prefix+Root", "Root+Suffix", "Compound", "—"];

const CAT_COLORS = {
  "Daily Life": { bg: "#FFF3E0", badge: "#FF8F00", text: "#4E342E" },
  "Sports":     { bg: "#E8F5E9", badge: "#2E7D32", text: "#1B5E20" },
  "Cars":       { bg: "#E3F2FD", badge: "#1565C0", text: "#0D47A1" },
  "Food":       { bg: "#FCE4EC", badge: "#C62828", text: "#880E4F" },
  "Work":       { bg: "#EDE7F6", badge: "#4527A0", text: "#311B92" },
  "Tech":       { bg: "#E0F7FA", badge: "#006064", text: "#004D40" },
};

const CAT_ICONS = {
  "Daily Life": "🏠", "Sports": "🏃", "Cars": "🚗",
  "Food": "🍎", "Work": "💼", "Tech": "💻"
};

export default function VocabApp() {
  const [activeCategory, setActiveCategory] = useState("All");
  const [activeRoot, setActiveRoot] = useState("All");
  const [search, setSearch] = useState("");
  const [expanded, setExpanded] = useState(null);
  const [today] = useState(new Date().toLocaleDateString("en-US", { weekday:"long", year:"numeric", month:"long", day:"numeric" }));

  const filtered = useMemo(() => vocab.filter(v => {
    const catOk = activeCategory === "All" || v.category === activeCategory;
    const rootOk = activeRoot === "All" || v.rootType === activeRoot;
    const searchOk = !search || v.word.toLowerCase().includes(search.toLowerCase()) ||
      v.fil.toLowerCase().includes(search.toLowerCase());
    return catOk && rootOk && searchOk;
  }), [activeCategory, activeRoot, search]);

  return (
    <div style={{ fontFamily:"'Georgia', serif", minHeight:"100vh", background:"#FAFAF7", color:"#1a1a1a" }}>
      {/* Header */}
      <div style={{
        background: "linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%)",
        padding: "40px 32px 32px",
        position: "relative",
        overflow: "hidden"
      }}>
        <div style={{ position:"absolute", inset:0, backgroundImage:"radial-gradient(circle at 20% 50%, rgba(255,200,100,0.08) 0%, transparent 60%), radial-gradient(circle at 80% 20%, rgba(100,180,255,0.08) 0%, transparent 50%)" }} />
        <div style={{ maxWidth:1100, margin:"0 auto", position:"relative" }}>
          <div style={{ display:"flex", justifyContent:"space-between", alignItems:"flex-start", flexWrap:"wrap", gap:16 }}>
            <div>
              <div style={{ fontSize:11, letterSpacing:4, color:"#ffd700", textTransform:"uppercase", marginBottom:8, fontFamily:"'Courier New', monospace" }}>
                Daily Vocabulary System · 每日词汇系统
              </div>
              <h1 style={{ margin:0, fontSize:"clamp(28px,5vw,52px)", fontWeight:900, color:"#fff", lineHeight:1.1, letterSpacing:-1 }}>
                Word<span style={{ color:"#ffd700" }}>Power</span>
                <span style={{ fontSize:"0.4em", color:"rgba(255,255,255,0.4)", marginLeft:12, fontWeight:400, letterSpacing:2 }}>EN · FIL</span>
              </h1>
              <p style={{ color:"rgba(255,255,255,0.55)", marginTop:10, fontSize:14, fontFamily:"sans-serif" }}>
                {today}
              </p>
            </div>
            <div style={{ display:"flex", gap:16, flexWrap:"wrap" }}>
              {[
                { n: vocab.length, label:"Total Words" },
                { n: filtered.length, label:"Showing" },
                { n: CATEGORIES.length - 1, label:"Categories" },
              ].map(s => (
                <div key={s.label} style={{ background:"rgba(255,255,255,0.07)", borderRadius:12, padding:"12px 20px", textAlign:"center", border:"1px solid rgba(255,255,255,0.1)" }}>
                  <div style={{ fontSize:28, fontWeight:800, color:"#ffd700", lineHeight:1 }}>{s.n}</div>
                  <div style={{ fontSize:11, color:"rgba(255,255,255,0.5)", marginTop:4, fontFamily:"sans-serif", letterSpacing:1 }}>{s.label.toUpperCase()}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div style={{ maxWidth:1100, margin:"0 auto", padding:"24px 20px" }}>

        {/* Principle Banner */}
        <div style={{ background:"#fff", borderRadius:16, padding:"20px 24px", marginBottom:24, border:"2px solid #f0e68c", display:"flex", gap:16, alignItems:"flex-start" }}>
          <div style={{ fontSize:28, flexShrink:0 }}>💡</div>
          <div>
            <div style={{ fontWeight:700, fontSize:16, marginBottom:6, color:"#1a1a1a" }}>词汇学习系统原理 · System Principle</div>
            <div style={{ fontSize:13, lineHeight:1.8, color:"#444", fontFamily:"sans-serif" }}>
              <b>① 词根词缀记忆法 (Root & Affix Method)</b>：通过掌握词根（如 <code style={{background:"#f5f5f5",padding:"1px 5px",borderRadius:4}}>hydro-</code>=水, <code style={{background:"#f5f5f5",padding:"1px 5px",borderRadius:4}}>port-</code>=运输）和词缀（前缀/后缀），一个词根可衍生出数十个单词，形成词汇网络，效率提升 3–5 倍。
              &nbsp;&nbsp;<b>② 场景分类法 (Contextual Clustering)</b>：按生活、运动、汽车等真实场景分类，帮助大脑建立「情境记忆」，遇到实际场景时词汇自然浮现。
              &nbsp;&nbsp;<b>③ 双语锚定 (Bilingual Anchoring)</b>：英语 + 菲律宾语同步学习，母语作为记忆锚点，加速理解同时保持思维灵活性。
            </div>
          </div>
        </div>

        {/* Search */}
        <div style={{ marginBottom:20 }}>
          <input
            value={search}
            onChange={e => setSearch(e.target.value)}
            placeholder="🔍  Search word or Filipino translation..."
            style={{ width:"100%", padding:"12px 18px", borderRadius:12, border:"2px solid #e0e0e0", fontSize:15, fontFamily:"sans-serif", outline:"none", boxSizing:"border-box", background:"#fff" }}
          />
        </div>

        {/* Category Filter */}
        <div style={{ marginBottom:12 }}>
          <div style={{ fontSize:11, letterSpacing:2, color:"#999", fontFamily:"sans-serif", marginBottom:8 }}>FILTER BY CATEGORY</div>
          <div style={{ display:"flex", gap:8, flexWrap:"wrap" }}>
            {CATEGORIES.map(c => (
              <button key={c} onClick={() => setActiveCategory(c)} style={{
                padding:"7px 16px", borderRadius:20, border:"2px solid",
                borderColor: activeCategory === c ? "#1a1a2e" : "#ddd",
                background: activeCategory === c ? "#1a1a2e" : "#fff",
                color: activeCategory === c ? "#fff" : "#555",
                cursor:"pointer", fontSize:13, fontFamily:"sans-serif", fontWeight:600,
                transition:"all 0.15s"
              }}>
                {c !== "All" ? CAT_ICONS[c] + " " : ""}{c}
              </button>
            ))}
          </div>
        </div>

        {/* Root Filter */}
        <div style={{ marginBottom:24 }}>
          <div style={{ fontSize:11, letterSpacing:2, color:"#999", fontFamily:"sans-serif", marginBottom:8 }}>FILTER BY ROOT/AFFIX TYPE</div>
          <div style={{ display:"flex", gap:6, flexWrap:"wrap" }}>
            {ROOT_TYPES.map(r => (
              <button key={r} onClick={() => setActiveRoot(r)} style={{
                padding:"5px 12px", borderRadius:20, border:"2px solid",
                borderColor: activeRoot === r ? "#ffd700" : "#eee",
                background: activeRoot === r ? "#ffd700" : "#fff",
                color: activeRoot === r ? "#1a1a2e" : "#777",
                cursor:"pointer", fontSize:11, fontFamily:"'Courier New', monospace", fontWeight:700,
                transition:"all 0.15s"
              }}>
                {r}
              </button>
            ))}
          </div>
        </div>

        {/* Table */}
        <div style={{ background:"#fff", borderRadius:20, overflow:"hidden", boxShadow:"0 4px 40px rgba(0,0,0,0.07)", border:"1px solid #eee" }}>
          {/* Table Header */}
          <div style={{
            display:"grid", gridTemplateColumns:"50px 1fr 1fr 1fr 130px 140px",
            padding:"14px 20px", background:"#1a1a2e", gap:8,
            fontSize:11, fontFamily:"sans-serif", letterSpacing:2, color:"rgba(255,255,255,0.6)", fontWeight:700
          }}>
            <div>#</div>
            <div>ENGLISH WORD</div>
            <div>FILIPINO · 菲律宾语</div>
            <div>ENGLISH DEFINITION</div>
            <div>CATEGORY</div>
            <div>ROOT · AFFIX</div>
          </div>

          {/* Rows */}
          {filtered.map((v, i) => {
            const colors = CAT_COLORS[v.category];
            const isExp = expanded === v.id;
            return (
              <div
                key={v.id}
                onClick={() => setExpanded(isExp ? null : v.id)}
                style={{
                  display:"grid", gridTemplateColumns:"50px 1fr 1fr 1fr 130px 140px",
                  padding: isExp ? "18px 20px" : "13px 20px",
                  gap:8, cursor:"pointer", alignItems:"center",
                  background: isExp ? colors.bg : (i % 2 === 0 ? "#fff" : "#FAFAF7"),
                  borderBottom:"1px solid #f0f0f0",
                  transition:"all 0.15s",
                }}
              >
                <div style={{ fontSize:12, color:"#bbb", fontFamily:"monospace", fontWeight:600 }}>
                  {String(v.id).padStart(2,"0")}
                </div>
                <div>
                  <div style={{ fontSize:17, fontWeight:800, color:"#1a1a2e", letterSpacing:-0.5 }}>{v.word}</div>
                  {isExp && (
                    <div style={{ marginTop:8, fontSize:12, color:"#555", fontFamily:"sans-serif", lineHeight:1.6, background:"rgba(0,0,0,0.04)", padding:"8px 12px", borderRadius:8 }}>
                      📖 {v.def}
                    </div>
                  )}
                </div>
                <div style={{ fontSize:14, color:"#333", fontFamily:"sans-serif", fontWeight:600 }}>{v.fil}</div>
                <div style={{ fontSize:12, color:"#666", fontFamily:"sans-serif", lineHeight:1.5, display: isExp ? "none" : "block" }}>
                  {v.def.length > 65 ? v.def.slice(0,65)+"…" : v.def}
                </div>
                {isExp && <div />}
                <div>
                  <span style={{
                    display:"inline-flex", alignItems:"center", gap:4,
                    background: colors.bg, color: colors.badge,
                    padding:"4px 10px", borderRadius:20, fontSize:11,
                    fontFamily:"sans-serif", fontWeight:700, border:`1.5px solid ${colors.badge}22`
                  }}>
                    {CAT_ICONS[v.category]} {v.category}
                  </span>
                </div>
                <div>
                  {v.rootType !== "—" ? (
                    <span style={{
                      display:"inline-block",
                      background:"#f0f4ff", color:"#3949AB",
                      padding:"3px 10px", borderRadius:20, fontSize:10,
                      fontFamily:"'Courier New', monospace", fontWeight:700,
                      maxWidth:"100%", overflow:"hidden", textOverflow:"ellipsis", whiteSpace:"nowrap"
                    }}>
                      {v.root}
                    </span>
                  ) : (
                    <span style={{ color:"#ccc", fontSize:12 }}>—</span>
                  )}
                </div>
              </div>
            );
          })}

          {filtered.length === 0 && (
            <div style={{ padding:48, textAlign:"center", color:"#aaa", fontFamily:"sans-serif" }}>
              No words match your filters. Try adjusting the search or filters above.
            </div>
          )}
        </div>

        {/* Footer Legend */}
        <div style={{ marginTop:24, display:"flex", gap:16, flexWrap:"wrap", justifyContent:"center" }}>
          {Object.entries(CAT_ICONS).map(([cat, icon]) => (
            <div key={cat} style={{ display:"flex", alignItems:"center", gap:6, fontSize:13, fontFamily:"sans-serif", color:"#555" }}>
              <span>{icon}</span><span style={{ color: CAT_COLORS[cat].badge, fontWeight:600 }}>{cat}</span>
            </div>
          ))}
        </div>
        <div style={{ textAlign:"center", marginTop:16, fontSize:12, color:"#bbb", fontFamily:"sans-serif" }}>
          Click any row to expand the full English definition · 点击任意行查看完整英文释义
        </div>
      </div>
    </div>
  );
}
